PGADMIN_DEFAULT_PASSWORD=admin

SPRING_PROFILES_ACTIVE=dev

# ── Database ──────────────────────────────────────────────────
# Points to the shared 'postgres' container on private_net
DB_HOST=postgres
DB_PORT=5432
POSTGRES_DB=resolvr_db
POSTGRES_USER=pguser
POSTGRES_PASSWORD=password

# ── JWT ───────────────────────────────────────────────────────
